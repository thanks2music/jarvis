        <mxCell id="sa5-p3-result" value="レビュー結果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="850" y="555" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="sa5-p3-e3" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=1;exitY=0.7;entryX=0;entryY=0.5;strokeColor=#82b366;" edge="1" parent="1" source="sa5-p3-agent" target="sa5-p3-result">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="When to Use SubAgent" id="page6-when-to-use">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0" darkMode="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Title -->
        <mxCell id="sa6-title" value="SubAgent 使用判断フロー" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="284" y="20" width="600" height="40" as="geometry" />
        </mxCell>
        <mxCell id="sa6-subtitle" value="タスクの性質に応じて SubAgent を使うかメインで直接やるかを判断する" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#666666;" vertex="1" parent="1">
