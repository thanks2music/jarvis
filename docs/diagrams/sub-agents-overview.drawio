        <mxCell id="sa5-p2-note" value="調査パスが互いに&#xa;依存しない場合に最も効果的" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="850" y="310" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sa5-p2-note-edge" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;dashed=1;strokeColor=#d6b656;" edge="1" parent="1" source="sa5-p2-integrate" target="sa5-p2-note">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Pattern 3: Security Review -->
        <mxCell id="sa5-p3-title" value="Pattern 3: セキュリティレビュー" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="350" height="25" as="geometry" />
        </mxCell>
        <mxCell id="sa5-p3-desc" value="カスタムサブエージェント security-reviewer で専門的なセキュリティ監査を実施" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="483" width="500" height="20" as="geometry" />
        </mxCell>
        <!-- Implementation -->
        <mxCell id="sa5-p3-impl" value="実装完了" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="515" width="140" height="45" as="geometry" />
        </mxCell>
        <!-- Trigger -->
        <mxCell id="sa5-p3-trigger" value="セキュリティレビューに&#xa;サブエージェントを使って" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="240" y="515" width="190" height="45" as="geometry" />
        </mxCell>
        <!-- Security Reviewer Agent -->
        <mxCell id="sa5-p3-agent" value="security-reviewer" style="swimlane;fontStyle=1;startSize=25;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="495" width="280" height="180" as="geometry" />
        </mxCell>
        <mxCell id="sa5-p3-agent-model" value="model: opus  |  tools: Read, Grep, Glob, Bash" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9;fontColor=#666666;" vertex="1" parent="sa5-p3-agent">
          <mxGeometry x="10" y="30" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="sa5-p3-check1" value="- SQL/XSS/コマンドインジェクション" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="sa5-p3-agent">
          <mxGeometry x="15" y="55" width="250" height="20" as="geometry" />
        </mxCell>
        <mxCell id="sa5-p3-check2" value="- 認証・認可の欠陥" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="sa5-p3-agent">
          <mxGeometry x="15" y="75" width="250" height="20" as="geometry" />
        </mxCell>
        <mxCell id="sa5-p3-check3" value="- コード内のシークレット・認証情報" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="sa5-p3-agent">
          <mxGeometry x="15" y="95" width="250" height="20" as="geometry" />
        </mxCell>
        <mxCell id="sa5-p3-check4" value="- 安全でないデータ処理" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="sa5-p3-agent">
          <mxGeometry x="15" y="115" width="250" height="20" as="geometry" />
        </mxCell>
        <mxCell id="sa5-p3-output" value="行番号付き指摘 + 修正案" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="sa5-p3-agent">
          <mxGeometry x="30" y="142" width="220" height="28" as="geometry" />
        </mxCell>
        <!-- Edges for Pattern 3 -->
        <mxCell id="sa5-p3-e1" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="sa5-p3-impl" target="sa5-p3-trigger">
          <mxGeometry relative="1" as="geometry" />
