        <mxCell id="sa5-p3-e2" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.3;strokeWidth=2;strokeColor=#b85450;" edge="1" parent="1" source="sa5-p3-trigger" target="sa5-p3-agent">
          <mxGeometry relative="1" as="geometry" />
