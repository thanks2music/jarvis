        <mxCell id="sa6-use-sa3-ex" value="例: 複数モジュールの同時調査&#xa;オンボーディング時の構造把握" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
