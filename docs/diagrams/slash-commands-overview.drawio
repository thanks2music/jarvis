  <diagram id="page2" name="Context Management Flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0" darkMode="0">
      <root>
        <mxCell id="sc2-0" />
        <mxCell id="sc2-1" parent="sc2-0" />
        <!-- Title -->
        <mxCell id="sc2-title" value="コンテキスト管理フロー" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="sc2-1">
          <mxGeometry x="400" y="20" width="400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="sc2-subtitle" value="コンテキストウィンドウの状態に応じた適切なコマンド選択" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#666666;" vertex="1" parent="sc2-1">
          <mxGeometry x="400" y="55" width="400" height="30" as="geometry" />
        </mxCell>
        <!-- Start: Session Start -->
        <mxCell id="sc2-start" value="会話開始" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="sc2-1">
          <mxGeometry x="80" y="120" width="140" height="60" as="geometry" />
        </mxCell>
        <!-- Context accumulation -->
        <mxCell id="sc2-accum" value="コンテキスト蓄積&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot; color=&quot;#666666&quot;&gt;会話・ファイル読み込み・&lt;br&gt;コマンド出力で消費&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="sc2-1">
          <mxGeometry x="310" y="115" width="180" height="70" as="geometry" />
        </mxCell>
        <!-- /context check -->
        <mxCell id="sc2-check" value="/context で&lt;br&gt;使用量を確認" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="sc2-1">
          <mxGeometry x="570" y="120" width="160" height="60" as="geometry" />
        </mxCell>
        <!-- Decision diamond -->
        <mxCell id="sc2-decision" value="状況の判断" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="sc2-1">
          <mxGeometry x="590" y="260" width="120" height="100" as="geometry" />
        </mxCell>
        <!-- Edge: start to accum -->
        <mxCell id="sc2-e1" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="sc2-1" source="sc2-start" target="sc2-accum">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Edge: accum to check -->
        <mxCell id="sc2-e2" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="sc2-1" source="sc2-accum" target="sc2-check">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Edge: check to decision -->
        <mxCell id="sc2-e3" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="sc2-1" source="sc2-check" target="sc2-decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Option 1: 60% over, /compact -->
        <mxCell id="sc2-opt1" value="&lt;b&gt;/compact [指示]&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot; color=&quot;#666666&quot;&gt;コンテキストを圧縮&lt;br&gt;会話の文脈は維持&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="sc2-1">
          <mxGeometry x="160" y="280" width="180" height="70" as="geometry" />
        </mxCell>
        <!-- Edge: decision to opt1 -->
        <mxCell id="sc2-e4" value="使用量 60% 超" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;fontSize=10;" edge="1" parent="sc2-1" source="sc2-decision" target="sc2-opt1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Option 2: Task switch, /clear -->
        <mxCell id="sc2-opt2" value="&lt;b&gt;/clear&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot; color=&quot;#666666&quot;&gt;コンテキスト完全リセット&lt;br&gt;新しいタスクに集中&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="sc2-1">
          <mxGeometry x="830" y="200" width="180" height="70" as="geometry" />
        </mxCell>
        <!-- Edge: decision to opt2 -->
        <mxCell id="sc2-e5" value="タスク完全切替" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=1;exitY=0.3;entryX=0;entryY=0.5;fontSize=10;" edge="1" parent="sc2-1" source="sc2-decision" target="sc2-opt2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Option 3: Failed approaches, /clear + new prompt -->
        <mxCell id="sc2-opt3" value="&lt;b&gt;/clear&lt;/b&gt; + より具体的な&lt;br&gt;プロンプトで再開&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot; color=&quot;#666666&quot;&gt;失敗アプローチの&lt;br&gt;汚染を排除&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="sc2-1">
          <mxGeometry x="830" y="310" width="180" height="80" as="geometry" />
        </mxCell>
        <!-- Edge: decision to opt3 -->
        <mxCell id="sc2-e6" value="2回以上修正失敗" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=1;exitY=0.7;entryX=0;entryY=0.5;fontSize=10;" edge="1" parent="sc2-1" source="sc2-decision" target="sc2-opt3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Option 4: Rewind -->
