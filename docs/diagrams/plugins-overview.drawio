        <!-- Decision 1: Multi-repo? -->
        <mxCell id="p6-d1" value="複数リポジトリで&lt;br&gt;再利用する？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="470" y="200" width="200" height="120" as="geometry" />
