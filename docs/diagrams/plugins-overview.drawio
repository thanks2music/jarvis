          <mxGeometry x="470" y="710" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p6-e6" value="No" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontColor=#b85450;fontStyle=1;fontSize=11;" edge="1" parent="1" source="p6-d3" target="p6-r4">
