          <mxGeometry x="790" y="395" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p6-e3" value="Yes" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontColor=#82b366;fontStyle=1;fontSize=11;" edge="1" parent="1" source="p6-d2" target="p6-r2">
          <mxGeometry relative="1" as="geometry" />
