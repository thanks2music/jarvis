        <mxCell id="p6-e-start" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p6-start" target="p6-d1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Result 1: Plugin (multi-repo) -->
        <mxCell id="p6-r1" value="&lt;b&gt;Plugin にまとめる&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;毎回コピーするより&lt;br&gt;Plugin にまとめて配布&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="790" y="225" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p6-e1" value="Yes" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontColor=#82b366;fontStyle=1;fontSize=11;" edge="1" parent="1" source="p6-d1" target="p6-r1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Decision 2: Team distribution? -->
        <mxCell id="p6-d2" value="チームや&lt;br&gt;コミュニティに&lt;br&gt;配布する？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="470" y="370" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p6-e2" value="No" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontColor=#b85450;fontStyle=1;fontSize=11;" edge="1" parent="1" source="p6-d1" target="p6-d2">
          <mxGeometry relative="1" as="geometry" />
