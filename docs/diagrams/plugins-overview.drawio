        <mxCell id="p6-e5" value="Yes" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontColor=#82b366;fontStyle=1;fontSize=11;" edge="1" parent="1" source="p6-d3" target="p6-r3">
          <mxGeometry relative="1" as="geometry" />
