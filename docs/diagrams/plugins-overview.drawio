<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io" type="device">
  <!-- Page 1: Plugin Architecture -->
  <diagram id="page1" name="Plugin Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" darkMode="0" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Title -->
        <mxCell id="p1-title" value="Plugin Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="p1-subtitle" value="Plugin と他の拡張機能の関係 - パッケージングレイヤーとしての役割" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="350" y="55" width="500" height="25" as="geometry" />
        </mxCell>
        <!-- Central Plugin box -->
        <mxCell id="p1-plugin" value="&lt;b&gt;Plugin&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;パッケージングレイヤー&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666666;&quot;&gt;Skills + Hooks + Agents + MCP を&lt;br&gt;1つのインストール可能なユニットに束ねる&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;verticalAlign=middle;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="180" width="340" height="120" as="geometry" />
        </mxCell>
        <!-- Skills component -->
        <mxCell id="p1-skills" value="&lt;b&gt;Skills&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;ドメイン知識&lt;br&gt;ワークフロー&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="180" y="120" width="150" height="70" as="geometry" />
        </mxCell>
        <!-- Hooks component -->
        <mxCell id="p1-hooks" value="&lt;b&gt;Hooks&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;イベント駆動の&lt;br&gt;自動化&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="870" y="120" width="150" height="70" as="geometry" />
        </mxCell>
        <!-- Subagents component -->
        <mxCell id="p1-agents" value="&lt;b&gt;Subagents&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;隔離されたタスク実行&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="180" y="290" width="150" height="70" as="geometry" />
        </mxCell>
        <!-- MCP component -->
        <mxCell id="p1-mcp" value="&lt;b&gt;MCP サーバー&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;外部サービス接続&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="870" y="290" width="150" height="70" as="geometry" />
        </mxCell>
        <!-- Edge: Skills to Plugin -->
        <mxCell id="p1-e1" value="バンドル" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.25;strokeColor=#82b366;fontColor=#82b366;fontSize=10;" edge="1" parent="1" source="p1-skills" target="p1-plugin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Edge: Hooks to Plugin -->
        <mxCell id="p1-e2" value="バンドル" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.25;strokeColor=#d6b656;fontColor=#d6b656;fontSize=10;" edge="1" parent="1" source="p1-hooks" target="p1-plugin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Edge: Subagents to Plugin -->
        <mxCell id="p1-e3" value="バンドル" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.75;strokeColor=#9673a6;fontColor=#9673a6;fontSize=10;" edge="1" parent="1" source="p1-agents" target="p1-plugin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Edge: MCP to Plugin -->
        <mxCell id="p1-e4" value="バンドル" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.75;strokeColor=#d79b00;fontColor=#d79b00;fontSize=10;" edge="1" parent="1" source="p1-mcp" target="p1-plugin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Namespace box -->
        <mxCell id="p1-namespace" value="&lt;b&gt;名前空間&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;plugin-name:skill-name&lt;br&gt;で競合を回避&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="340" width="240" height="55" as="geometry" />
        </mxCell>
        <!-- Edge: Plugin to Namespace -->
        <mxCell id="p1-e5" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;dashed=1;strokeColor=#666666;" edge="1" parent="1" source="p1-plugin" target="p1-namespace">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Note: Skill vs Plugin granularity -->
        <mxCell id="p1-note-group" value="" style="swimlane;fontStyle=1;startSize=26;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="440" width="540" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p1-note-title" value="Skill vs Plugin の粒度の違い" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;" vertex="1" parent="p1-note-group">
          <mxGeometry x="140" y="0" width="260" height="30" as="geometry" />
        </mxCell>
        <mxCell id="p1-skill-box" value="&lt;b&gt;Skill（単体）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;単一の指示・ワークフロー&lt;br&gt;ファイル配置のみ&lt;br&gt;Git リポジトリに含める&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="p1-note-group">
          <mxGeometry x="20" y="40" width="230" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p1-plugin-box" value="&lt;b&gt;Plugin（バンドル）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Skills + Hooks + Agents + MCP&lt;br&gt;/plugin install コマンド&lt;br&gt;マーケットプレイスで配布&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="p1-note-group">
          <mxGeometry x="290" y="40" width="230" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p1-note-arrow" value="パッケージング" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#666666;fontSize=10;fontColor=#666666;" edge="1" parent="p1-note-group" source="p1-skill-box" target="p1-plugin-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1-note-text" value="Plugin なしでも個別に使える。再利用・配布が必要な場合に Plugin にまとめる" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#666666;" vertex="1" parent="p1-note-group">
          <mxGeometry x="70" y="130" width="400" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
