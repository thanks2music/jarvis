  <!-- Page 6: Plugin vs Skill Decision -->
  <diagram id="page6" name="Plugin vs Skill">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" darkMode="0" math="0" shadow="0">
