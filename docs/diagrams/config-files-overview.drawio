        <!-- Arrow 2 to 3 -->
        <mxCell id="cf2-e23" style="edgeStyle=orthogonalEdgeStyle;curved=1;html=1;endArrow=classic;endFill=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="cf2-p2" target="cf2-p3">
