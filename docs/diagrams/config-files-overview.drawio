        </mxCell>

        <!-- Priority 1: Managed -->
        <mxCell id="cf2-p1" value="1. Managed（企業管理設定）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="284" y="110" width="350" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cf2-p1-note" value="最優先。他のどのレベルでも上書き不可。&#xa;組織が配布する設定。個人環境では通常不要。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
