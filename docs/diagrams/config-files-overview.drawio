        <mxCell id="cf2-p2-note" value="セッション単位の一時的なオーバーライド。&#xa;例: --allowedTools, --model" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
